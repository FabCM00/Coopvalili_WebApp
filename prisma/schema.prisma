generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?            @db.Timestamptz(6)
  image               String?
  passwordHash        String?
  role                Role                 @default(USER)
  active              Boolean              @default(false)
  createdAt           DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  sentInvitations     InvitationToken[]    @relation("InvitedBy")
  passwordResetTokens PasswordResetToken[]

  @@index([email], map: "idx_user_email")
  @@index([role], map: "idx_user_role")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime @db.Timestamptz(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_user")

  @@index([token], map: "idx_password_reset_token")
  @@index([userId], map: "idx_password_reset_userid")
}

model InvitationToken {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  role        Role     @default(USER)
  invitedById String
  expiresAt   DateTime @db.Timestamptz(6)
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  invitedBy   User     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_invitation_invited_by")

  @@index([email], map: "idx_invitation_email")
  @@index([token], map: "idx_invitation_token")
}

model credito_decisiones {
  radicado        String          @id
  opcion_elegida  String?
  response        Json?
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?       @default(now()) @db.Timestamptz(6)
  valida1_results valida1_results @relation(fields: [radicado], references: [radicado], onDelete: Cascade, onUpdate: NoAction, map: "fk_credito_valida1")
}

model datos_asociado {
  cedula                String    @id
  primer_apellido       String?
  nombre                String?
  ciudad                String?
  estado_civil          String?
  estado_civil_norm     String?
  edad                  Int?
  personas_cargo        Int?
  cliente_empresa       String?
  fecha_ingreso         String?
  fecha_ingreso_empresa String?
  antiguedad_coop       Decimal?  @db.Decimal
  antiguedad_laboral    Decimal?  @db.Decimal
  salario               Decimal?  @db.Decimal
  aportes               Decimal?  @db.Decimal
  deuda_coopvalili      Decimal?  @db.Decimal
  usuario_credito       String?
  tipo_vivienda         String?
  nivel                 String?
  cuota_disponible      Decimal?  @db.Decimal
  nombre_asociado       String?
  raw_json              Json?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)

  @@index([cedula], map: "idx_datos_asociado_cedula")
}

model identity_validations {
  id                BigInt          @id @default(autoincrement())
  radicado_valida1  String          @unique
  cedula            String
  tipo_validacion   String?
  status_document   String?
  status_face       String?
  estado_validacion String?
  request_json      Json?
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?       @default(now()) @db.Timestamptz(6)
  valida1_results   valida1_results @relation(fields: [radicado_valida1], references: [radicado], onDelete: Cascade, onUpdate: NoAction, map: "fk_identity_valida1")

  @@index([cedula], map: "idx_identity_cedula")
}

