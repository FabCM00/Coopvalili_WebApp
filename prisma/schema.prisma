  monto_solicitado        Decimal?         @db.Decimal
  parametro_credito       Decimal?         @db.Decimal
  instancia_aprobacion    String?
  ahorros_fondo           Decimal?         @db.Decimal
  fecha_ingreso           String?
  fecha_nacimiento        String?
  edad                    Int?
  personas_cargo          Int?
  tipo_vivienda           String?
  antiguedad_fondo        Decimal?         @db.Decimal
  antiguedad_laboral      Decimal?         @db.Decimal
  tasa_usura              Decimal?         @db.Decimal
  tasa_usura_per          Decimal?         @db.Decimal
  plazo_tarjetas          Int?
  meta_coopvalili         String?
  meta_transunion         String?
  meta_mensaje            String?
  raw_json                Json?
  created_at              DateTime?        @default(now()) @db.Timestamptz(6)
  valida1_results         valida1_results? @relation(fields: [radicado_valida1], references: [radicado], onUpdate: NoAction, map: "fk_motor_data_valida1")

  @@index([cedula], map: "idx_motor_data_cedula")
  @@index([created_at(sort: Desc)], map: "idx_motor_data_created")
  @@index([radicado_valida1], map: "idx_motor_data_radicado")
}

